# ── App ──────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# ── MongoDB ───────────────────────────
MONGODB_URI=mongodb://admin:secret@localhost:27017/jamb_cbt?authSource=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secret

# ── Redis ─────────────────────────────
REDIS_URL=redis://:redispassword@localhost:6379
REDIS_PASSWORD=redispassword

# ── Elasticsearch ─────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── RabbitMQ ──────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── JWT (RS256 — generate a real keypair) ─
JWT_PRIVATE_
JWT_PUBLIC_
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Auth / OAuth ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Notifications ─────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@jambcbt.ng
TERMII_API_KEY=
TERMII_SENDER_ID=JAMBCBT

# ── File Storage ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=eu-west-1
# If S3 env vars are empty, files save to /uploads locally

# ── Deployment (Cloudflare Pages + DigitalOcean) ──
CF_PAGES_PROJECT_NAME=jamb-cbt-frontend
DO_APP_NAME=jamb-cbt-backend
